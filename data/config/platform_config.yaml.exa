default_parser_proxies: http://127.0.0.1:7890
default_downloader_proxies:
  - http://127.0.0.1:7890
platforms:
  twitter:
    disable_downloader_proxy: true
    parser_proxies: []
    downloader_proxies: []
    cookies:
      - auth_token=xxxx; ct0=xxxx
  bilibili:
    disable_parser_proxy: true
    disable_downloader_proxy: true